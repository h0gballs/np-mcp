# Where the MCP server listens (streamable HTTP). Hermes connects to
# http://<host>:<port>/mcp
NP_MCP_HOST=127.0.0.1
NP_MCP_PORT=8721

# Where check_events persists its between-call state.
STATE_PATH=data/state.json

# OPTIONAL: Neptune's Pride account credentials, only needed for the
# get_messages tool and new_message events. Uses the unofficial login API;
# everything else works without these.
#NP_EMAIL=you@example.com
#NP_PASSWORD=your_np_password
